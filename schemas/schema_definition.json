{
  "append_job": {
    "required": ["action", "site", "job_title", "category", "client", "deadline", "url", "status"],
    "optional": ["reward_min", "reward_max", "applications", "contracts", "result", "memo"],
    "fields": {
      "action": "append_job",
      "site": "string (例: crowdworks, lancers)",
      "job_title": "string",
      "category": "string",
      "reward_min": "string (空文字可)",
      "reward_max": "string (空文字可)",
      "client": "string",
      "applications": "number or string",
      "contracts": "string (例: 0/1)",
      "deadline": "string (YYYY-MM-DD形式推奨)",
      "url": "string (案件URL)",
      "status": "string (例: 未応募, 応募済, 見送り)",
      "result": "string (空文字可)",
      "memo": "string (空文字可)"
    }
  },
  "update_status": {
    "required": ["action", "site", "url", "status"],
    "optional": ["applied_at", "memo"],
    "fields": {
      "action": "update_status",
      "site": "string",
      "url": "string (URLキーで行を特定するため必須)",
      "status": "string",
      "applied_at": "string (YYYY-MM-DD形式推奨, 空文字可)",
      "memo": "string (空文字可)"
    }
  }
}
